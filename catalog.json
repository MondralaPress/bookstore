  {
    "id": "wheels-templars",
    "title": "Mr. Wheels and the Templar Treasure",
    "author": "Zbigniew Nienacki",
    "translator": "Tom Pinch",
    "cover": "covers/wheels-templars.jpg",
    "shelves": [
