  {
    "id": "wheels-bandits",
    "title": "Mr. Wheels and the Island of Bandits",
    "author": "Zbigniew Nienacki",
    "translator": "Tom Pinch",
    "cover": "covers/wheels-bandits.jpg",
    "shelves": [
